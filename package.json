{
  "name": "sanegit",
  "version": "0.2.4",
  "description": "SaneGit Command Assistant CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/ntufar/sanegit"
  },
  "type": "module",
  "bin": {
    "sg": "dist/src/cli.js"
  },
  "main": "dist/src/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/contract",
    "test:hosting": "vitest run tests/contract/hosting.contract.test.ts tests/unit/hostingProvider.test.ts",
    "test:workflow": "vitest run tests/unit/workflowState.test.ts tests/integration/ship.integration.test.ts",
    "test:wtf-learning": "vitest run tests/unit/patternLearner.test.ts tests/integration/wtf.integration.test.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "keytar": "^7.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "prettier": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
